# Copy to .env and adjust per environment. Vite only exposes vars prefixed VITE_.

# Django backend base URL (no trailing slash). Points at Nginx's /api/ proxy in production.
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Google Analytics 4 (leave blank to disable — no script loads without it)
VITE_GA_MEASUREMENT_ID=

# Google Tag Manager container ID, e.g. GTM-XXXXXXX (leave blank to disable
# — no script loads without it). Independent of GA4 above; enable either,
# both, or neither.
VITE_GTM_ID=

# Google Search Console HTML tag verification value (the `content` from
# Settings → Ownership verification → HTML tag). Leave blank until you have
# a real value — an empty meta tag is harmless, it just won't verify.
VITE_GSC_VERIFICATION=
